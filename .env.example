# Banco (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/adota_pet?schema=public"

# SMTP (Hostinger) — variáveis lidas pelo EmailService
EMAIL_SERVICE_HOST=smtp.hostinger.com
EMAIL_SERVICE_USER=
EMAIL_SERVICE_PASSWORD=

# Opcionais: porta padrão 465; secure true quando porta 465
# EMAIL_SERVICE_PORT=465
# EMAIL_SERVICE_SECURE=true

# Remetente (se vazio, usa EMAIL_SERVICE_USER)
# EMAIL_SERVICE_FROM="AdotaPet <no-reply@exemplo.com>"

# URL da tela de login do frontend (link no e-mail de aprovação de abrigo)
# APP_PUBLIC_LOGIN_URL=http://localhost:5173/login
